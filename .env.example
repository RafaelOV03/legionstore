# .env.example - Copiar a .env y ajustar según necesidad
# Nota: archivo de ejemplo, no usar en producción sin revisar valores

# Backend Configuration
# GIN_MODE puede ser debug, release o test (release recomendado en despliegue)
GIN_MODE=release
PORT=8080

# Frontend Configuration
# URL base que consume el frontend para llamar al backend
VITE_API_URL=http://backend:8080

# Database
# En Docker Compose, DB_HOST suele ser el nombre del servicio (backend)
DB_HOST=backend
DB_NAME=legionstore.db
# Si cambias nombres de variables aquí, actualiza también README y .env real
